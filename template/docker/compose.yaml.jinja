services:
  web:
    image: ${IMAGE}
    restart: unless-stopped
    environment:
      NODE_ENV: production
    env_file:
      - path: secrets.env
        required: false
    ports:
      # Host port from platform.env (§ 5.4 PLX) — assigned by the platform from
      # the tenant's inventory, never hardcoded. No fallback: a missing binding
      # fails loudly. Container port stays 3000 (the app's own concern).
      - "127.0.0.1:${PLEXUS_APP_PORT}:3000"
    labels:
      plexus.tenant: {{ _copier_answers.tenant }}
    healthcheck:
      test:
        - CMD
        - node
        - -e
        - "fetch('http://127.0.0.1:3000/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
