services:
  web:
    image: ${IMAGE}
    restart: unless-stopped
    environment:
      NODE_ENV: production
    env_file:
      - path: secrets.env
        required: false
    ports:
      - "127.0.0.1:3000:3000"
    labels:
      plexus.tenant: {{ _copier_answers.tenant }}
    healthcheck:
      test:
        - CMD
        - node
        - -e
        - "fetch('http://127.0.0.1:3000/healthz').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
